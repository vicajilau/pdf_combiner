# Auto detect text files and normalize line endings to LF
* text=auto

# Dart and Flutter files - always use LF
*.dart text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
pubspec.lock text eol=lf
pubspec.yaml text eol=lf

# Source files - always use LF
*.java text eol=lf
*.kt text eol=lf
*.swift text eol=lf
*.h text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.c text eol=lf

# Web files - always use LF
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.gz binary
*.zip binary
*.7z binary
*.ttf binary
*.otf binary
